# Hindsight Configuration
# Copy this file to .env and fill in your values

# LM Studio API token (get from LM Studio > Settings > Developer)
LM_API_TOKEN=your-token-here

# Path to your local lmstudio-js SDK (required for image-summarizer)
# Clone from: https://github.com/nicholsonjf/lmstudio-js
# Then point to the publish/sdk directory
LMSTUDIO_SDK_PATH=/path/to/lmstudio-js/publish/sdk

# API server port
PORT=3000

# Screenshot capture interval in minutes
CAPTURE_INTERVAL=5

# Vision model to use for screenshot summarization
VISION_MODEL=qwen/qwen3-vl-4b

# Web dashboard port
WEB_PORT=5173
